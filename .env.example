# ============================================================
# A.Z.E. — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# ห้าม commit ไฟล์ .env ขึ้น Git เด็ดขาด!
# ============================================================

# ─── Gemini API Key Rotation (Feature 7) ─────────────────
# เพิ่ม key ได้สูงสุด 10 บัญชี (1 บัญชี = 1,500 req/day)
# รวมสูงสุด = 15,000 req/day = ทำงาน Non-Stop ตลอด 24 ชม.
#
# วิธีสร้าง key ฟรี: https://aistudio.google.com/app/apikey
# สร้างหลาย Google account → หลาย free key ได้เลย!

GEMINI_API_KEY_1=AIzaSy_YOUR_ACCOUNT_A_KEY_HERE
GEMINI_API_KEY_2=AIzaSy_YOUR_ACCOUNT_B_KEY_HERE
GEMINI_API_KEY_3=AIzaSy_YOUR_ACCOUNT_C_KEY_HERE
# GEMINI_API_KEY_4=AIzaSy_YOUR_ACCOUNT_D_KEY_HERE
# GEMINI_API_KEY_5=AIzaSy_YOUR_ACCOUNT_E_KEY_HERE

# Legacy single key (ใช้ถ้ามี key เดียว — ไม่แนะนำ)
# GEMINI_API_KEY=AIzaSy_YOUR_SINGLE_KEY_HERE

# ─── LINE Notify (optional) ──────────────────────────────
# รับแจ้งเตือนเมื่อ quota ใกล้หมด + ทุก key exhausted
# สร้าง token: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ─── TEST MODE (Zero-Quota Testing Switch) ───────────────
# true  = ข้ามทุก API ที่เสีย quota (Gemini, TTS) คืน Mock Data
#         ระบบรัน Pipeline จนครบ ไม่มีค่าใช้จ่ายใดๆ ✅
# false = เรียก API จริง (ตั้งค่านี้เฉพาะตอน production จริงๆ)
TEST_MODE=true

# ─── Environment Mode ─────────────────────────────────────
# "mock"       = ทดสอบฟรี ไม่เรียก API จริง
# "production" = ระบบจริง เรียก Gemini + โพสต์จริง
ENVIRONMENT=mock

# ─── Shopee Affiliate (optional) ─────────────────────────
# SHOPEE_AFFILIATE_ID=your_affiliate_id
